{
  "expo": {
    "name": "Vigor",
    "slug": "vigor",
    "scheme": "vigor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": { "supportsTablet": false, "bundleIdentifier": "com.vigor.app" },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#000000" }, "package": "com.vigor.app" },
    "plugins": [
      "expo-router",
      ["react-native-mmkv", {}]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
