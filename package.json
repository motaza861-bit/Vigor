{
  "name": "vigor",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "expo": "~54.0.0",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "~2.12.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.5.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.10",
    "babel-jest": "^30.4.1",
    "babel-preset-expo": "~54.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "tailwindcss": "3.3.2",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "haste": {
      "defaultPlatform": "ios",
      "platforms": [
        "android",
        "ios",
        "native"
      ]
    },
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transform": {
      "\\.[jt]sx?$": [
        "babel-jest",
        {
          "presets": [
            [
              "@babel/preset-env",
              {
                "targets": {
                  "node": "current"
                },
                "modules": "commonjs"
              }
            ],
            "@babel/preset-typescript",
            [
              "@babel/preset-react",
              {
                "runtime": "automatic"
              }
            ]
          ]
        }
      ]
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(react-native|@react-native|@react-native-community|react-native-mmkv|react-native-reanimated|react-native-svg|react-native-worklets|expo-camera|expo-modules-core)/)"
    ],
    "moduleNameMapper": {
      "^react-native/Libraries/Utilities/Platform(\\.ios|\\.android|\\.native)?$": "<rootDir>/jestMocks/Platform.js",
      "^react-native/Libraries/Utilities/Platform\\.js$": "<rootDir>/jestMocks/Platform.js",
      "^react-native-worklets$": "<rootDir>/jestMocks/react-native-worklets.js",
      "^react-native-worklets/package\\.json$": "<rootDir>/jestMocks/react-native-worklets-package.json",
      "^react-native-worklets/(.*)$": "<rootDir>/jestMocks/react-native-worklets.js",
      "^react-native-reanimated/mock$": "<rootDir>/jestMocks/react-native-reanimated-mock.js",
      "^react-native-reanimated/scripts/validate-worklets-version$": "<rootDir>/jestMocks/validate-worklets-version.js"
    }
  },
  "private": true
}
